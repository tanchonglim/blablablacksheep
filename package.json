{
  "name": "blablablacksheep",
  "version": "1.0.0",
  "description": "Configurable enterprise API mock system with batch file generation",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "tailwindcss -i src/styles/input.css -o public/tailwind.css --minify && cp node_modules/alpinejs/dist/cdn.min.js public/alpine.min.js",
    "build:watch": "tailwindcss -i src/styles/input.css -o public/tailwind.css --watch",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8",
    "@fastify/view": "^10",
    "@readme/openapi-parser": "^6.0.0",
    "alpinejs": "^3.15.10",
    "better-sqlite3": "^11",
    "csv-stringify": "^6",
    "ejs": "^3",
    "fastify": "^5",
    "node-cron": "^3",
    "randexp": "^0.5.3",
    "uuid": "^11"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  }
}
