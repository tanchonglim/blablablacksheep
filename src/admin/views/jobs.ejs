<% currentPage = 'jobs'; %>

<h1 class="text-xl font-semibold text-white mb-5">Batch Jobs</h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  <!-- Scripts -->
  <div>
    <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Available Scripts</h2>
    <% if (scripts.length === 0) { %>
    <div class="card text-sm text-slate-500">
      No scripts found. Add <code class="font-mono text-xs bg-slate-800 text-slate-300 px-1.5 py-0.5 rounded">.js</code>
      files to the <code class="font-mono text-xs bg-slate-800 text-slate-300 px-1.5 py-0.5 rounded">scripts/</code> directory.
    </div>
    <% } %>
    <% scripts.forEach(function(s) { %>
    <div class="card">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <div class="font-semibold text-sm text-white"><%= s.name %></div>
          <div class="text-xs font-mono text-slate-500 mt-0.5"><%= s.file %></div>
          <% if (s.cron) { %>
          <div class="flex items-center gap-1.5 text-xs text-slate-400 mt-2">
            <svg class="w-3 h-3 text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <code class="font-mono text-slate-300 bg-slate-800 px-1.5 py-0.5 rounded"><%= s.cron %></code>
          </div>
          <% } else { %>
          <div class="text-xs text-slate-500 mt-2">Manual only</div>
          <% } %>
          <% if (s.description) { %>
          <div class="text-xs text-slate-400 mt-1.5"><%= s.description %></div>
          <% } %>
          <% if (s.error) { %>
          <div class="text-xs text-red-400 mt-1.5 font-mono">Error: <%= s.error %></div>
          <% } %>
        </div>
        <% if (!s.error) { %>
        <button class="btn-primary btn-sm shrink-0" onclick="triggerJob('<%= s.file %>', this)">▶ Run now</button>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- Run history -->
  <div>
    <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Recent Runs</h2>
    <% if (runs.length === 0) { %>
    <div class="card text-sm text-slate-500">No runs yet.</div>
    <% } %>
    <% runs.forEach(function(r) { %>
    <div class="bg-slate-900 border border-slate-800 rounded-lg p-3 mb-3">
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div class="flex items-center gap-2">
          <span class="font-semibold text-sm text-white"><%= r.script_name %></span>
          <span class="badge badge-default"><%= r.triggered_by %></span>
        </div>
        <span class="badge <%= r.status === 'success' ? 'badge-success' : r.status === 'error' ? 'badge-error' : 'badge-running' %>">
          <%= r.status %>
        </span>
      </div>
      <div class="text-xs text-slate-500 mt-1 font-mono"><%= r.started_at %></div>
      <% if (r.output_files) { %>
      <% const files = JSON.parse(r.output_files || '[]'); %>
      <% if (files.length > 0) { %>
      <div class="flex items-center flex-wrap gap-1.5 text-xs mt-2">
        <span class="text-slate-500">Files:</span>
        <% files.forEach(function(f) { %>
        <a href="/admin/files/download/<%= encodeURIComponent(f) %>"
           class="font-mono text-blue-400 hover:text-blue-300 transition-colors bg-blue-950/30 px-1.5 py-0.5 rounded"><%= f %></a>
        <% }); %>
      </div>
      <% } %>
      <% } %>
      <% if (r.error) { %>
      <div class="text-xs text-red-400 mt-1.5 font-mono"><%= r.error %></div>
      <% } %>
      <% if (r.logs) { %>
      <% const logs = JSON.parse(r.logs || '[]'); %>
      <% if (logs.length > 0) { %>
      <div x-data="{ open: false }" class="mt-2">
        <button @click="open=!open" type="button" class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-slate-200 transition-colors">
          <svg :class="open && 'rotate-90'" class="w-2 h-2 transition-transform fill-current text-slate-600 shrink-0" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
          Logs (<%= logs.length %>)
        </button>
        <div x-show="open" x-cloak
             x-transition:enter="transition ease-out duration-100" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
             class="mt-1.5">
          <pre class="text-xs font-mono bg-slate-800/60 border border-slate-700/50 rounded p-2 overflow-x-auto text-slate-300"><%= logs.join('\n') %></pre>
        </div>
      </div>
      <% } %>
      <% } %>
    </div>
    <% }); %>
  </div>

</div>

<script>
  async function triggerJob(file, btn) {
    btn.disabled = true;
    btn.textContent = '⏳ Running…';
    try {
      const result = await apiPost('/admin/jobs/trigger', { file });
      if (result.ok) {
        btn.textContent = '✓ Done';
        showToast('Job completed', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        btn.textContent = '✗ Failed';
        showToast('Job failed', 'error');
        alert('Job failed: ' + (result.error || 'Unknown error'));
        setTimeout(() => { btn.disabled = false; btn.textContent = '▶ Run now'; }, 2000);
      }
    } catch (err) {
      btn.textContent = '✗ Error';
      showToast('Request error', 'error');
      alert('Request error: ' + err.message);
      setTimeout(() => { btn.disabled = false; btn.textContent = '▶ Run now'; }, 2000);
    }
  }
</script>
