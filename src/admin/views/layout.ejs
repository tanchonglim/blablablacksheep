<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BlaBlaBlackSheep — Mock System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/tailwind.css">
  <script defer src="/static/alpine.min.js"></script>
  <style>
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #020617; }
    ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #475569; }
    body {
      background-image: radial-gradient(circle at 1px 1px, rgba(100,116,139,0.06) 1px, transparent 0);
      background-size: 28px 28px;
    }
    [x-cloak] { display: none !important; }
  </style>
</head>
<body class="bg-slate-950 text-slate-300 font-sans min-h-screen">

  <nav class="bg-slate-900/95 backdrop-blur border-b border-slate-800 sticky top-0 z-50">
    <div class="max-w-[1400px] mx-auto px-6 flex items-center h-14 gap-1">
      <a href="/admin" class="font-display font-extrabold text-white text-[15px] tracking-tight mr-6 hover:text-blue-300 transition-colors">
        BlaBla<span class="text-blue-400">Black</span>Sheep
      </a>
      <a href="/admin/endpoints" class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors <%- currentPage === 'endpoints' ? 'bg-blue-600/20 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-slate-800' %>">Endpoints</a>
      <a href="/admin/requests"  class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors <%- currentPage === 'requests'  ? 'bg-blue-600/20 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-slate-800' %>">Requests</a>
      <a href="/admin/jobs"      class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors <%- currentPage === 'jobs'      ? 'bg-blue-600/20 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-slate-800' %>">Jobs</a>
      <a href="/admin/files"     class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors <%- currentPage === 'files'     ? 'bg-blue-600/20 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-slate-800' %>">Output Files</a>
    </div>
  </nav>

  <main class="max-w-[1400px] mx-auto px-6 py-8">
    <%- body %>
  </main>

  <script>
    async function apiPost(url, data) {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      return res.json();
    }

    function formPost(url, data) {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = url;
      for (const [k, v] of Object.entries(data)) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = k;
        input.value = v;
        form.appendChild(input);
      }
      document.body.appendChild(form);
      form.submit();
    }

    function showToast(msg, type = 'default') {
      let t = document.getElementById('_toast');
      if (!t) {
        t = document.createElement('div');
        t.id = '_toast';
        t.style.cssText = 'position:fixed;bottom:24px;right:24px;display:flex;align-items:center;gap:10px;padding:11px 16px;border-radius:10px;font-size:13px;font-family:"IBM Plex Sans",sans-serif;font-weight:500;z-index:9999;transition:opacity .25s,transform .25s;box-shadow:0 8px 32px rgba(0,0,0,0.5);';
        document.body.appendChild(t);
      }
      const styles = {
        default: { bg: '#1e293b', border: '1px solid #334155', color: '#e2e8f0', dot: '#64748b' },
        success: { bg: '#052e16', border: '1px solid #166534', color: '#86efac', dot: '#22c55e' },
        error:   { bg: '#450a0a', border: '1px solid #991b1b', color: '#fca5a5', dot: '#ef4444' },
      };
      const s = styles[type] || styles.default;
      t.style.background = s.bg;
      t.style.border = s.border;
      t.style.color = s.color;
      t.innerHTML = `<span style="width:6px;height:6px;border-radius:50%;background:${s.dot};flex-shrink:0"></span>${msg}`;
      t.style.opacity = '1';
      t.style.transform = 'translateY(0)';
      clearTimeout(t._tmr);
      t._tmr = setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(4px)'; }, 2200);
    }
  </script>
</body>
</html>
