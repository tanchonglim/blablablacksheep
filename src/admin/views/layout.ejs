<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BlaBlaBlackSheep — Mock System</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; margin: 0; background: #f5f5f5; color: #1a1a1a; }
    nav { background: #1a1a2e; color: #fff; padding: 0 24px; display: flex; align-items: center; gap: 24px; height: 52px; }
    nav a { color: #ccc; text-decoration: none; font-size: 14px; padding: 4px 8px; border-radius: 4px; }
    nav a:hover, nav a.active { color: #fff; background: #ffffff22; }
    nav .brand { font-weight: 700; color: #fff; font-size: 16px; margin-right: 16px; }
    main { padding: 24px; max-width: 1400px; margin: 0 auto; }
    h1 { font-size: 22px; margin: 0 0 20px; }
    h2 { font-size: 16px; margin: 0 0 12px; }
    .card { background: #fff; border: 1px solid #e0e0e0; border-radius: 8px; padding: 16px; margin-bottom: 16px; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .badge-success { background: #dcfce7; color: #166534; }
    .badge-error { background: #fee2e2; color: #991b1b; }
    .badge-custom { background: #fef3c7; color: #92400e; }
    .badge-default { background: #e0e0e0; color: #555; }
    .badge-running { background: #dbeafe; color: #1e40af; }
    .badge-get { background: #d1fae5; color: #065f46; }
    .badge-post { background: #dbeafe; color: #1e40af; }
    .badge-put { background: #fef3c7; color: #92400e; }
    .badge-patch { background: #ede9fe; color: #5b21b6; }
    .badge-delete { background: #fee2e2; color: #991b1b; }
    .btn { padding: 6px 14px; border-radius: 6px; border: none; cursor: pointer; font-size: 13px; font-weight: 500; }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-danger { background: #ef4444; color: #fff; }
    .btn-danger:hover { background: #dc2626; }
    .btn-secondary { background: #e5e7eb; color: #374151; }
    .btn-secondary:hover { background: #d1d5db; }
    .btn-sm { padding: 3px 10px; font-size: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 8px 12px; background: #f9fafb; border-bottom: 2px solid #e0e0e0; color: #555; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; }
    td { padding: 8px 12px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
    tr:hover td { background: #fafafa; }
    input, select, textarea { border: 1px solid #d1d5db; border-radius: 6px; padding: 6px 10px; font-size: 13px; font-family: inherit; width: 100%; }
    textarea { font-family: 'Courier New', monospace; font-size: 12px; }
    .flex { display: flex; gap: 8px; align-items: center; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .text-sm { font-size: 12px; color: #666; }
    .text-mono { font-family: 'Courier New', monospace; font-size: 12px; }
    details summary { cursor: pointer; user-select: none; font-weight: 600; font-size: 13px; }
    details summary:hover { color: #2563eb; }
    .scenario-row { border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; margin-top: 8px; }
    .alert { padding: 10px 14px; border-radius: 6px; margin-bottom: 12px; font-size: 13px; }
    .alert-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }
    pre { background: #f8f8f8; border: 1px solid #e0e0e0; border-radius: 4px; padding: 10px; font-size: 12px; overflow-x: auto; margin: 0; white-space: pre-wrap; word-break: break-all; }
    .pagination { display: flex; gap: 8px; margin-top: 16px; align-items: center; font-size: 13px; }
    .pagination a { padding: 4px 10px; border: 1px solid #e0e0e0; border-radius: 4px; text-decoration: none; color: #374151; }
    .pagination a:hover { background: #f3f4f6; }
    .pagination .current { padding: 4px 10px; background: #2563eb; color: #fff; border-radius: 4px; }
  </style>
</head>
<body>
  <nav>
    <span class="brand">BlaBlaBlackSheep</span>
    <a href="/admin/endpoints" class="<%= currentPage === 'endpoints' ? 'active' : '' %>">Endpoints</a>
    <a href="/admin/requests" class="<%= currentPage === 'requests' ? 'active' : '' %>">Requests</a>
    <a href="/admin/jobs" class="<%= currentPage === 'jobs' ? 'active' : '' %>">Jobs</a>
    <a href="/admin/files" class="<%= currentPage === 'files' ? 'active' : '' %>">Output Files</a>
  </nav>
  <main>
    <%- body %>
  </main>
  <script>
    // Generic JSON POST helper
    async function apiPost(url, data) {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      return res.json();
    }

    // Form POST helper (for redirect-based forms)
    function formPost(url, data) {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = url;
      for (const [k, v] of Object.entries(data)) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = k;
        input.value = v;
        form.appendChild(input);
      }
      document.body.appendChild(form);
      form.submit();
    }
  </script>
</body>
</html>
