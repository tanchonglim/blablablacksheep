<% currentPage = 'files'; %>

<h1 class="text-xl font-semibold text-white mb-5">Output Files</h1>

<div class="bg-slate-900 border border-slate-800 rounded-lg overflow-hidden">
  <table class="w-full" style="border-collapse:collapse">
    <thead>
      <tr>
        <th class="th">Filename</th>
        <th class="th">Size</th>
        <th class="th">Last modified</th>
        <th class="th" style="width:100px"></th>
      </tr>
    </thead>
    <tbody>
      <% if (files.length === 0) { %>
      <tr>
        <td colspan="4" class="td text-center text-slate-500 py-12">
          <div class="flex flex-col items-center gap-2">
            <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span class="text-sm">No output files yet</span>
            <span class="text-xs text-slate-600">Trigger a batch job to generate files</span>
          </div>
        </td>
      </tr>
      <% } %>
      <% files.forEach(function(f) { %>
      <tr class="hover:bg-slate-800/30 transition-colors">
        <td class="td">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <code class="font-mono text-sm text-slate-200"><%= f.name %></code>
          </div>
        </td>
        <td class="td text-xs text-slate-400 font-mono"><%= (f.size / 1024).toFixed(1) %> KB</td>
        <td class="td text-xs text-slate-400 font-mono"><%= f.mtime %></td>
        <td class="td">
          <a href="/admin/files/download/<%= encodeURIComponent(f.name) %>" class="btn-secondary btn-sm">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download
          </a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
