<% currentPage = 'requests'; %>

<h1>Stored Requests</h1>

<div class="card" style="padding:12px">
  <form method="get" action="/admin/requests" class="flex" style="flex-wrap:wrap;gap:8px;align-items:flex-end">
    <div>
      <label class="text-sm">Endpoint</label>
      <select name="endpoint" style="width:220px">
        <option value="">All endpoints</option>
        <% endpoints.forEach(function(e) { %>
        <option value="<%= e %>" <%= endpoint === e ? 'selected' : '' %>><%= e %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label class="text-sm">Status code</label>
      <input name="status" value="<%= status || '' %>" placeholder="e.g. 200" style="width:100px">
    </div>
    <button type="submit" class="btn btn-primary btn-sm">Filter</button>
    <a href="/admin/requests" class="btn btn-secondary btn-sm">Clear</a>
    <div style="margin-left:auto">
      <button type="button" class="btn btn-danger btn-sm"
        onclick="if(confirm('Delete all stored requests?')) apiPost('/admin/requests/clear', {}).then(() => location.reload())">
        Clear all
      </button>
    </div>
  </form>
</div>

<div class="card" style="padding:0;overflow:hidden">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Time</th>
        <th>Endpoint</th>
        <th>Status</th>
        <th>Request body</th>
        <th>Response body</th>
      </tr>
    </thead>
    <tbody>
      <% if (rows.length === 0) { %>
      <tr><td colspan="6" style="text-align:center;color:#888;padding:24px">No requests yet</td></tr>
      <% } %>
      <% rows.forEach(function(row) { %>
      <tr>
        <td class="text-mono"><%= row.id %></td>
        <td class="text-sm" style="white-space:nowrap"><%= row.created_at %></td>
        <td>
          <span class="badge badge-<%= row.method.toLowerCase() %>"><%= row.method %></span>
          <code style="font-size:12px"><%= row.path %></code>
        </td>
        <td>
          <span class="badge <%= row.response_status < 300 ? 'badge-success' : 'badge-error' %>">
            <%= row.response_status %>
          </span>
        </td>
        <td style="max-width:200px">
          <details>
            <summary class="text-sm">View</summary>
            <pre><%= row.request_body || '—' %></pre>
          </details>
        </td>
        <td style="max-width:220px">
          <details>
            <summary class="text-sm">View</summary>
            <pre><%= row.response_body || '—' %></pre>
          </details>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<% const totalPages = Math.ceil(total / limit); %>
<% if (totalPages > 1) { %>
<div class="pagination">
  <span class="text-sm"><%= total %> records</span>
  <% if (page > 1) { %>
  <a href="/admin/requests?page=<%= page - 1 %><%= endpoint ? '&endpoint=' + encodeURIComponent(endpoint) : '' %><%= status ? '&status=' + status : '' %>">← Prev</a>
  <% } %>
  <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
  <% if (p === page) { %><span class="current"><%= p %></span>
  <% } else { %>
  <a href="/admin/requests?page=<%= p %><%= endpoint ? '&endpoint=' + encodeURIComponent(endpoint) : '' %><%= status ? '&status=' + status : '' %>"><%= p %></a>
  <% } %>
  <% } %>
  <% if (page < totalPages) { %>
  <a href="/admin/requests?page=<%= page + 1 %><%= endpoint ? '&endpoint=' + encodeURIComponent(endpoint) : '' %><%= status ? '&status=' + status : '' %>">Next →</a>
  <% } %>
</div>
<% } %>
